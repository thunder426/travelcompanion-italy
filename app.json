{
  "expo": {
    "name": "Travel Companion",
    "slug": "travelcompanion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to translate text and identify artworks",
"NSLocationAlwaysAndWhenInUseUsageDescription": "Used to warn you of ZTL zones while driving",
        "NSLocationWhenInUseUsageDescription": "Used to show your position on the map",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.thunderexpo.travelcompanion"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Travel Companion to access your camera to translate text and identify artworks."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Travel Companion to use your location for ZTL zone warnings."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "b4eec5f5-0a06-4c80-82ed-f0c44cd52eaa"
      }
    }
  }
}
